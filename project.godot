; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="MissileCommandClone"
run/main_scene="res://Scene/MainMenu.tscn"
config/features=PackedStringArray("4.2")

[autoload]

GameManager="*res://Scripts/GameManager.gd"

[display]

window/stretch/mode="viewport"
mouse_cursor/custom_image="res://assets/Crosshair2.png"
mouse_cursor/custom_image_hotspot=Vector2(16, 16)

[dotnet]

project/assembly_name="MissileCommandClone"

[gui]

theme/custom="res://assets/Themes/main_theme.tres"

[rendering]

textures/vram_compression/import_etc2_astc=true
